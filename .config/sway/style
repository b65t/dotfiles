# client.class          <border> <background> <text> <indicator> <child_border>
client.focused          $background  $background      $foreground $background    $background
client.focused_inactive $color8  $color8      $foreground $color8    $color8
client.unfocused        $color8  $color8      $foreground $color8    $color8

default_border normal 0.5
default_floating_border none
corner_radius 8

blur disable

shadows enable
shadow_color $background
shadow_offset 7 7 0 0
shadow_blur_radius 8

gaps inner 6

title_align center
font "noto sans Nerd Font Bold 10"
titlebar_border_thickness 0

for_window {
    [app_id="firefox"] border pixel 2
}

include "$HOME/.cache/wal/colors-sway"
